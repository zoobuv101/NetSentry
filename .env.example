# ============================================================================
# NetSentry — Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values.
# Lines starting with # are comments. All values shown are defaults.
# Required values are marked [REQUIRED].
# ============================================================================

# ── Application ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
DB_PATH=/data/netsentry.db

# ── API ───────────────────────────────────────────────────────────────────────
API_PORT=8282                 # Port NetSentry listens on
# API_KEY=                    # Optional: require X-API-Key header

# ── HTTPS (optional) ─────────────────────────────────────────────────────────
# HTTPS=false
# TLS_CERT_PATH=/config/cert.pem
# TLS_KEY_PATH=/config/key.pem

# ── Scanner ───────────────────────────────────────────────────────────────────
# SCAN_SUBNETS=               # e.g. 192.168.1.0/24,192.168.10.0/24
#                             # Leave blank to auto-detect from host interfaces
SCAN_INTERVAL_ARP=300         # ARP sweep interval (seconds)
SCAN_INTERVAL_PORTS=900       # TCP port scan interval (seconds)
SCAN_RATE_LIMIT=1000          # Max packets per second (lower on busy networks)
SCAN_OFFLINE_THRESHOLD=2      # Missed cycles before device marked offline

# ── TP-Link Deco Integration ─────────────────────────────────────────────────
ENABLE_DECO_INTEGRATION=true
DECO_HOST=192.168.68.1        # [REQUIRED if Deco enabled] IP of main Deco node
DECO_USERNAME=                # [REQUIRED if Deco enabled] Owner account username
DECO_PASSWORD=                # [REQUIRED if Deco enabled] Owner account password
DECO_POLL_INTERVAL=30         # Polling interval in seconds (minimum 10)

# ── pfSense Integration ───────────────────────────────────────────────────────
ENABLE_PFSENSE_INTEGRATION=true
PFSENSE_API_URL=              # [REQUIRED if pfSense enabled] e.g. https://192.168.1.1
PFSENSE_API_KEY=              # [REQUIRED if pfSense enabled] pfSense REST API key
PFSENSE_VERIFY_SSL=false      # Set true if pfSense has a valid TLS cert

# ── AdGuard Home Integration ─────────────────────────────────────────────────
ENABLE_ADGUARD_INTEGRATION=true
ADGUARD_URL=                  # [REQUIRED if AdGuard enabled] e.g. http://192.168.1.2:3000
ADGUARD_USERNAME=             # [REQUIRED if AdGuard enabled]
ADGUARD_PASSWORD=             # [REQUIRED if AdGuard enabled]

# ── ntfy Push Notifications ──────────────────────────────────────────────────
# For self-hosted ntfy (included in this Compose stack):
NTFY_URL=http://localhost:2586
NTFY_TOPIC=netsentry
# NTFY_TOKEN=                 # Optional: ntfy access token
# NTFY_UPSTREAM_BASE_URL=https://ntfy.sh   # Required for iOS push delivery

# ── Telegram Notifications ────────────────────────────────────────────────────
ENABLE_TELEGRAM=false
# TELEGRAM_BOT_TOKEN=         # From BotFather — keep this secret!
# TELEGRAM_CHAT_ID=           # Your Telegram chat/channel ID

# ── AI Device Identification (optional) ──────────────────────────────────────
# AI identification is DISABLED by default to prevent unexpected API costs.
# Enable only if you have an Anthropic API key and want enhanced device ID.
ENABLE_AI_IDENTIFICATION=false
# ANTHROPIC_API_KEY=          # Your Anthropic API key — keep this secret!
# AI_IDENTIFICATION_MODEL=claude-haiku-4-5-20251001
# AI_IDENTIFICATION_CONFIDENCE_THRESHOLD=0.6
# AI_MAX_CALLS_PER_CYCLE=10

# ── Internet Speed Testing ────────────────────────────────────────────────────
ENABLE_SPEEDTEST=true
SPEEDTEST_BACKEND=librespeed  # Options: librespeed (recommended), ookla, fast
SPEEDTEST_INTERVAL=21600      # 6 hours
# SPEEDTEST_DOWNLOAD_THRESHOLD_MBPS=0    # 0 = no alerting
# SPEEDTEST_LATENCY_THRESHOLD_MS=0       # 0 = no alerting

# To use the self-hosted LibreSpeed server, start with:
#   docker compose --profile librespeed up -d
# Then set:
ENABLE_LIBRESPEED=false
# When LibreSpeed is running, set:
# NTFY_URL=http://localhost:2586  (already set above)

# ── Availability Monitoring ───────────────────────────────────────────────────
AVAILABILITY_MAX_MONITORED=50

# ── Optional Redis Cache ─────────────────────────────────────────────────────
# Enable if you have >150 devices and notice API slowness.
# Start with: docker compose --profile redis up -d
ENABLE_REDIS_CACHE=false
